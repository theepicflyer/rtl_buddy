# CDC timing exceptions for cdc_ref_top (XDC)
# Generated by `rb cdc --emit-constraints` from the verified
# crossing set — do not hand-edit; regenerate when the RTL changes.

create_clock -name clk_a -period 8.0 [get_ports {clk_a}]
create_clock -name clk_b -period 10.0 [get_ports {clk_b}]
set_clock_groups -asynchronous -group {clk_a} -group {clk_b}

set_max_delay -datapath_only 10.0 -from [get_cells -hierarchical cdc_ref_top/*] -to [get_cells -hierarchical u_flag_sync/*]
set_max_delay -datapath_only 10.0 -from [get_cells -hierarchical cdc_ref_top/*] -to [get_cells -hierarchical u_gray_sync/*]
set_bus_skew 10.0 -from [get_cells -hierarchical cdc_ref_top/*] -to [get_cells -hierarchical u_gray_sync/*]
set_max_delay -datapath_only 10.0 -from [get_cells -hierarchical u_hs/*] -to [get_cells -hierarchical u_hs/*]
set_bus_skew 10.0 -from [get_cells -hierarchical u_hs/*] -to [get_cells -hierarchical u_hs/*]
set_max_delay -datapath_only 10.0 -from [get_cells -hierarchical u_hs/*] -to [get_cells -hierarchical u_hs/u_req_sync/*]
set_max_delay -datapath_only 8.0 -from [get_cells -hierarchical u_hs/*] -to [get_cells -hierarchical u_hs/u_ack_sync/*]

set_false_path -to [get_cells -hierarchical u_rst_a/*]
set_false_path -to [get_cells -hierarchical u_rst_b/*]
